<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/green_low"
    tools:context=".ActivityExam">

    <!-- HEADER -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="118dp"
        android:background="@drawable/bg_green_rounded_top"
        android:orientation="horizontal"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginTop="40dp"
            android:layout_marginStart="20dp"
            android:text="Matematika"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="@android:color/black"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center_vertical|end">

            <TextView
                android:text="Waktu tersisa"
                android:textSize="14sp"
                android:textColor="@android:color/white"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/tv_timer"
                android:text="10:00"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>
    </LinearLayout>

    <!-- ROW SOAL + MENU -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/soal_row"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:layout_marginStart="30dp"
        android:layout_marginEnd="30dp"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- TEXT SOAL -->
        <TextView
            android:id="@+id/soal_1_textview"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Soal 1 dari 20"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/menu_btn"
            app:layout_constraintTop_toTopOf="parent"/>

        <!-- ICON MENU -->
        <ImageView
            android:id="@+id/menu_btn"
            android:layout_width="32dp"
            android:layout_height="28dp"
            android:background="@drawable/bg_circle_green"
            android:padding="6dp"
            android:src="@drawable/more_menu"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- PROGRESS -->
    <ProgressBar
        android:id="@+id/progressBar"
        style="@android:style/Widget.ProgressBar.Horizontal"
        android:layout_width="0dp"
        android:layout_height="20dp"
        android:layout_marginTop="16dp"
        android:layout_marginStart="30dp"
        android:layout_marginEnd="30dp"
        android:max="100"
        android:progress="10"
        android:progressTint="@color/green_primary"
        android:progressBackgroundTint="@color/white"
        app:layout_constraintTop_toBottomOf="@id/soal_row"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- SOAL -->
    <TextView
        android:id="@+id/tvSoal"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:textColor="@color/black"
        android:layout_marginStart="30dp"
        android:layout_marginEnd="30dp"
        android:layout_marginTop="20dp"
        android:justificationMode="inter_word"
        app:layout_constraintTop_toBottomOf="@id/progressBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <ImageView
        android:id="@+id/imgSoal"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:scaleType="fitStart"
        app:layout_constraintTop_toBottomOf="@id/tvSoal"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- OPSI -->
    <LinearLayout
        android:id="@+id/options_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="30dp"
        android:layout_marginEnd="30dp"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/imgSoal"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- OPSI A -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/optionA"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="12dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:elevation="6dp"
            app:cardCornerRadius="30dp"
            app:cardBackgroundColor="@android:color/white">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:textSize="16sp"
                android:textColor="@android:color/black"/>
        </com.google.android.material.card.MaterialCardView>

        <!-- OPSI B -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/optionB"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="12dp"
            android:elevation="6dp"
            app:cardCornerRadius="30dp"
            app:cardBackgroundColor="@android:color/white">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:textSize="16sp"/>
        </com.google.android.material.card.MaterialCardView>

        <!-- OPSI C -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/optionC"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="12dp"
            android:elevation="6dp"
            app:cardCornerRadius="30dp"
            app:cardBackgroundColor="@android:color/white">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:textSize="16sp"/>
        </com.google.android.material.card.MaterialCardView>

        <!-- OPSI D -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/optionD"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="12dp"
            android:elevation="6dp"
            app:cardCornerRadius="30dp"
            app:cardBackgroundColor="@android:color/white">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:textSize="16sp"/>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

    <!-- BUTTON -->
    <Button
        android:id="@+id/bt_prev"
        android:layout_width="wrap_content"
        android:layout_height="60dp"
        android:text="Sebelumnya"
        android:backgroundTint="@color/orange"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/options_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/bt_next"/>

    <Button
        android:id="@+id/bt_next"
        android:layout_width="wrap_content"
        android:layout_height="60dp"
        android:text="Berikutnya"
        android:backgroundTint="@color/green_primary"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/options_container"
        app:layout_constraintStart_toEndOf="@id/bt_prev"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>